<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LocoCalc.ViewModels"
        xmlns:conv="using:LocoCalc.Converters"
        xmlns:models="using:LocoCalc.Models"
        x:Class="LocoCalc.Views.MainWindow"
        Title="LocoCalc"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="620"
        Background="#1e1e2e"
        FontFamily="Segoe UI, Sans-Serif">

  <Window.Resources>
    <conv:BrakesEnabledToColorConverter x:Key="BrakesColor" />
  </Window.Resources>

  <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="280,*,250">

    <!-- ═══ HEADER ══════════════════════════════════════════════════════════ -->
    <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
            Background="#12121f" Padding="20,11"
            BorderBrush="#3a3a55" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto,Auto">

        <!-- Logo -->
        <StackPanel Orientation="Horizontal" Spacing="12">
          <TextBlock Text="🚂" FontSize="24" VerticalAlignment="Center"/>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="LocoCalc" FontSize="19" FontWeight="Bold" Foreground="#f97316"/>
            <TextBlock Text="{Binding L.AppSubtitle}" FontSize="11" Foreground="#6b6b8a"/>
          </StackPanel>
        </StackPanel>

        <!-- Language switcher CS / EN -->
        <Border Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBlock Text="CS" FontSize="12" VerticalAlignment="Center"
                       Foreground="{Binding IsCzech, Converter={x:Static BoolConverters.Not},
                                    ConverterParameter=dim}"/>
            <ToggleSwitch IsChecked="{Binding IsEnglish}"
                          OnContent="" OffContent=""
                          VerticalAlignment="Center"
                          MinWidth="0"/>
            <TextBlock Text="EN" FontSize="12" VerticalAlignment="Center"
                       Foreground="#a0a0c0"/>
          </StackPanel>
        </Border>

        <!-- Braking % badge -->
        <Border Grid.Column="2" Background="#f97316" CornerRadius="8" Padding="20,8">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBlock Text="{Binding L.BrakingWeightLabel}" Foreground="White"
                       FontSize="13" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding BrakingPercentageDisplay}"
                       Foreground="White" FontSize="22" FontWeight="Bold"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <!-- ═══ ERROR BAR (hidden when empty) ══════════════════════════════════ -->
    <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
            Background="#7f1d1d" Padding="16,8"
            IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0"
                   Text="{Binding ErrorMessage}"
                   Foreground="#fca5a5" FontSize="13" VerticalAlignment="Center"
                   TextWrapping="Wrap"/>
        <Button Grid.Column="1"
                Content="✕"
                Command="{Binding ClearErrorCommand}"
                Background="Transparent" Foreground="#fca5a5"
                FontSize="14" Padding="10,0" VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <!-- ═══════════════════════════════════════════════════════════════════
         LEFT PANEL — Locomotive catalogue
    ════════════════════════════════════════════════════════════════════════ -->
    <Border Grid.Row="2" Grid.Column="0"
            Background="#2a2a3e" BorderBrush="#3a3a55" BorderThickness="0,0,1,0">
      <Grid RowDefinitions="Auto,*,Auto">

        <Border Grid.Row="0" Padding="14,12,14,10"
                BorderBrush="#3a3a55" BorderThickness="0,0,0,1">
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding L.PanelLocomotives}"
                       FontSize="11" FontWeight="Bold"
                       Foreground="#6b6b8a" LetterSpacing="2"/>
            <Button Content="{Binding L.ReloadFromDisk}"
                    Command="{Binding RefreshLocosCommand}"
                    HorizontalAlignment="Stretch"
                    Background="#1e1e2e" Foreground="#a0a0c0"
                    FontSize="12" Padding="8,5" CornerRadius="4"/>
          </StackPanel>
        </Border>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding AvailableLocos}"
                 SelectedItem="{Binding SelectedLoco}"
                 Background="Transparent" Padding="8">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:LocomotiveDefinition">
              <Border Padding="10,8" CornerRadius="6" Margin="0,2"
                      Background="#1e1e2e">
                <StackPanel>
                  <TextBlock Text="{Binding Designation}"
                             FontWeight="SemiBold" Foreground="#e2e2f0" FontSize="13"/>
                  <TextBlock FontSize="11" Foreground="#6b6b8a">
                    <Run Text="{Binding TotalWeightTonnes}"/>
                    <Run Text=" t  ·  "/>
                    <Run Text="{Binding BrakingWeightTonnes}"/>
                    <Run Text=" t brake"/>
                  </TextBlock>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="2" Padding="12,10"
                BorderBrush="#3a3a55" BorderThickness="0,1,0,0">
          <Button Content="{Binding L.AddToConsist}"
                  Command="{Binding AddLocoToConsistCommand}"
                  IsEnabled="{Binding SelectedLoco, Converter={x:Static ObjectConverters.IsNotNull}}"
                  HorizontalAlignment="Stretch"
                  Background="#f97316" Foreground="White"
                  FontWeight="Bold" FontSize="13"
                  Padding="0,10" CornerRadius="6"/>
        </Border>
      </Grid>
    </Border>

    <!-- ═══════════════════════════════════════════════════════════════════
         CENTRE — Consist builder
    ════════════════════════════════════════════════════════════════════════ -->
    <Grid Grid.Row="2" Grid.Column="1" RowDefinitions="Auto,*,Auto,Auto">

      <!-- Consist name + save/new -->
      <Border Grid.Row="0" Padding="14,10"
              BorderBrush="#3a3a55" BorderThickness="0,0,0,1"
              Background="#1e1e2e">
        <Grid ColumnDefinitions="*,Auto,Auto,Auto">
          <TextBox Grid.Column="0"
                   Text="{Binding ConsistName}"
                   Watermark="{Binding L.ConsistNamePlaceholder}"
                   Background="#2a2a3e" Foreground="#e2e2f0"
                   BorderBrush="#3a3a55" CornerRadius="5"
                   Padding="10,6" FontSize="13" Margin="0,0,8,0"/>
          <Button Grid.Column="1"
                  Content="{Binding L.SaveButton}"
                  Command="{Binding SaveConsistCommand}"
                  Background="#3b82f6" Foreground="White"
                  FontWeight="Bold" Padding="14,7" CornerRadius="5"
                  Margin="0,0,6,0"/>
          <Button Grid.Column="2"
                  Content="{Binding L.NewButton}"
                  Command="{Binding NewConsistCommand}"
                  Background="#2a2a3e" Foreground="#a0a0c0"
                  Padding="14,7" CornerRadius="5"
                  Margin="0,0,6,0"/>
          <TextBlock Grid.Column="3"
                     Text="{Binding StatusMessage}"
                     Foreground="#22c55e" VerticalAlignment="Center"
                     FontSize="12" MaxWidth="160" TextWrapping="Wrap"/>
        </Grid>
      </Border>

      <!-- ── Consist entry rows ── -->
      <ScrollViewer Grid.Row="1" Padding="10,8">
        <ItemsControl ItemsSource="{Binding ConsistEntries}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ConsistEntryViewModel">
              <Border Margin="0,4" CornerRadius="8" Padding="14,10"
                      Background="#2a2a3e"
                      BorderBrush="{Binding BrakesEnabled, Converter={StaticResource BrakesColor}}"
                      BorderThickness="3,0,0,0">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">

                  <!-- Loco info -->
                  <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{Binding Designation}"
                               FontWeight="Bold" Foreground="#e2e2f0" FontSize="14"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                      <TextBlock FontSize="11" Foreground="#6b6b8a">
                        <Run Text="{Binding TotalWeightTonnes}"/>
                        <Run Text=" t"/>
                      </TextBlock>
                      <TextBlock FontSize="11" Foreground="#6b6b8a">
                        <Run Text="{Binding BrakingWeightTonnes}"/>
                        <Run Text=" t"/>
                      </TextBlock>
                    </StackPanel>
                  </StackPanel>

                  <!-- Position badge — read-only, derived from consist order -->
                  <Border Grid.Column="1" VerticalAlignment="Center"
                          Margin="10,0" Padding="10,5"
                          CornerRadius="4" Background="#3a3a55">
                    <TextBlock Text="{Binding PositionDisplay}"
                               FontSize="12" Foreground="#e2e2f0"
                               FontWeight="SemiBold"/>
                  </Border>

                  <!-- Brakes toggle — validates through ToggleBrakesCommand -->
                  <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                              VerticalAlignment="Center" Margin="0,0,6,0">
                    <Button Content="{Binding BrakesButtonText}"
                            Background="{Binding BrakesEnabled, Converter={StaticResource BrakesColor}}"
                            Foreground="White"
                            IsEnabled="{Binding !BrakesLocked}"
                            Command="{Binding $parent[Window].DataContext.ToggleBrakesCommand}"
                            CommandParameter="{Binding}"
                            Width="72" Padding="0,6"
                            FontSize="11" FontWeight="SemiBold"
                            CornerRadius="5"/>
                    <!-- EDB toggle badge — only visible for EDB-capable locos at Front -->
                    <Button Content="EDB"
                            IsVisible="{Binding HasEDB}"
                            Command="{Binding $parent[Window].DataContext.ToggleEdbCommand}"
                            CommandParameter="{Binding}"
                            FontSize="10" FontWeight="Bold"
                            Padding="6,6" CornerRadius="5"
                            ToolTip.Tip="{Binding $parent[Window].DataContext.L.EdbDialogTitle}">
                      <Button.Styles>
                        <Style Selector="Button">
                          <Setter Property="Background" Value="#3a3a55"/>
                          <Setter Property="Foreground" Value="#a0a0c0"/>
                        </Style>
                      </Button.Styles>
                      <Button.Background>
                        <MultiBinding Converter="{x:Static BoolConverters.Or}">
                          <Binding Path="EdbActive"/>
                        </MultiBinding>
                      </Button.Background>
                    </Button>
                  </StackPanel>

                  <!-- Move up / down -->
                  <StackPanel Grid.Column="3" Orientation="Horizontal"
                              Spacing="4" VerticalAlignment="Center" Margin="4,0">
                    <Button Content="↑"
                            Command="{Binding $parent[Window].DataContext.MoveUpCommand}"
                            CommandParameter="{Binding}"
                            Background="#3a3a55" Foreground="#e2e2f0"
                            Width="28" Height="28" Padding="0" FontSize="13" CornerRadius="4"/>
                    <Button Content="↓"
                            Command="{Binding $parent[Window].DataContext.MoveDownCommand}"
                            CommandParameter="{Binding}"
                            Background="#3a3a55" Foreground="#e2e2f0"
                            Width="28" Height="28" Padding="0" FontSize="13" CornerRadius="4"/>
                  </StackPanel>

                  <!-- Remove -->
                  <Button Grid.Column="4"
                          Content="✕"
                          Command="{Binding $parent[Window].DataContext.RemoveEntryCommand}"
                          CommandParameter="{Binding}"
                          Background="Transparent" Foreground="#ef4444"
                          Width="28" Height="28" Padding="0"
                          FontSize="14" VerticalAlignment="Center"
                          Margin="4,0,0,0" CornerRadius="4"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- ── Visual consist strip ── -->
      <Border Grid.Row="2" Background="#12121f" Padding="12,10"
              BorderBrush="#3a3a55" BorderThickness="0,1,0,1">
        <StackPanel Spacing="6">
          <TextBlock Text="{Binding L.ConsistOverview}"
                     FontSize="10" FontWeight="Bold"
                     Foreground="#6b6b8a" LetterSpacing="2"/>
          <ScrollViewer HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding ConsistEntries}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="3"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ConsistEntryViewModel">
                  <Border CornerRadius="4" Padding="8,6" Width="88"
                          Background="#2a2a3e"
                          BorderBrush="{Binding BrakesEnabled, Converter={StaticResource BrakesColor}}"
                          BorderThickness="0,0,0,3"
                          ToolTip.Tip="{Binding Designation}">
                    <StackPanel Spacing="2">
                      <TextBlock Text="🚂" FontSize="15" HorizontalAlignment="Center"/>
                      <TextBlock Text="{Binding Designation}"
                                 FontSize="9" Foreground="#a0a0c0"
                                 TextWrapping="Wrap" TextAlignment="Center"
                                 MaxLines="2"/>
                      <TextBlock Text="{Binding PositionDisplay}"
                                 FontSize="8" TextAlignment="Center"
                                 Foreground="{Binding BrakesEnabled, Converter={StaticResource BrakesColor}}"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </StackPanel>
      </Border>

      <!-- ── Summary stats ── -->
      <Border Grid.Row="3" Background="#12121f" Padding="16,10">
        <Grid ColumnDefinitions="*,*,*,*,*">
          <StackPanel Grid.Column="0">
            <TextBlock Text="{Binding L.StatLocos}"
                       FontSize="9" Foreground="#6b6b8a" FontWeight="Bold" LetterSpacing="1"/>
            <TextBlock Text="{Binding ConsistEntries.Count}"
                       FontSize="18" FontWeight="Bold" Foreground="#e2e2f0"/>
          </StackPanel>
          <StackPanel Grid.Column="1">
            <TextBlock Text="{Binding L.StatTotalWeight}"
                       FontSize="9" Foreground="#6b6b8a" FontWeight="Bold" LetterSpacing="1"/>
            <TextBlock Text="{Binding TotalWeightDisplay}"
                       FontSize="18" FontWeight="Bold" Foreground="#e2e2f0"/>
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Text="DÉLKA / LENGTH"
                       FontSize="9" Foreground="#6b6b8a" FontWeight="Bold" LetterSpacing="1"/>
            <TextBlock Text="{Binding TotalLengthDisplay}"
                       FontSize="18" FontWeight="Bold" Foreground="#e2e2f0"/>
          </StackPanel>
          <StackPanel Grid.Column="3">
            <TextBlock Text="{Binding L.StatActiveBrake}"
                       FontSize="9" Foreground="#6b6b8a" FontWeight="Bold" LetterSpacing="1"/>
            <TextBlock Text="{Binding ActiveBrakeWeightDisplay}"
                       FontSize="18" FontWeight="Bold" Foreground="#22c55e"/>
          </StackPanel>
          <StackPanel Grid.Column="4">
            <TextBlock Text="{Binding L.StatBrakingPct}"
                       FontSize="9" Foreground="#f97316" FontWeight="Bold" LetterSpacing="1"/>
            <TextBlock Text="{Binding BrakingPercentageDisplay}"
                       FontSize="18" FontWeight="Bold" Foreground="#f97316"/>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <!-- ═══════════════════════════════════════════════════════════════════
         RIGHT PANEL — Saved consists
    ════════════════════════════════════════════════════════════════════════ -->
    <Border Grid.Row="2" Grid.Column="2"
            Background="#2a2a3e" BorderBrush="#3a3a55" BorderThickness="1,0,0,0">
      <Grid RowDefinitions="Auto,*">

        <Border Grid.Row="0" Padding="14,12,14,10"
                BorderBrush="#3a3a55" BorderThickness="0,0,0,1">
          <TextBlock Text="{Binding L.SavedConsists}"
                     FontSize="11" FontWeight="Bold"
                     Foreground="#6b6b8a" LetterSpacing="2"/>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="8">
          <ItemsControl ItemsSource="{Binding SavedConsists}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:Consist">
                <Border Margin="0,3" CornerRadius="6" Padding="10,8"
                        Background="#1e1e2e">
                  <Grid RowDefinitions="Auto,Auto,Auto">
                    <TextBlock Grid.Row="0"
                               Text="{Binding Name}"
                               FontWeight="SemiBold" Foreground="#e2e2f0"
                               FontSize="12" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Row="1" FontSize="10" Foreground="#6b6b8a"
                               Margin="0,2,0,6">
                      <Run Text="{Binding Entries.Count}"/>
                      <Run Text=" lok. · "/>
                      <Run Text="{Binding LastModified, StringFormat={}{0:dd MMM HH:mm}}"/>
                    </TextBlock>
                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                      <Button Grid.Column="0"
                              Content="{Binding $parent[Window].DataContext.L.LoadButton}"
                              Command="{Binding $parent[Window].DataContext.LoadConsistCommand}"
                              CommandParameter="{Binding}"
                              Background="#3b82f6" Foreground="White"
                              FontSize="11" Padding="0,5"
                              HorizontalAlignment="Stretch"
                              CornerRadius="4" Margin="0,0,4,0"/>
                      <Button Grid.Column="1"
                              Content="✕"
                              Command="{Binding $parent[Window].DataContext.DeleteConsistCommand}"
                              CommandParameter="{Binding}"
                              Background="Transparent" Foreground="#ef4444"
                              FontSize="13" Width="28" Height="28"
                              Padding="0" CornerRadius="4"/>
                    </Grid>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

  </Grid>
</Window>