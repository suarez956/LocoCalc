<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocoCalc.ViewModels"
             xmlns:models="using:LocoCalc.Models"
             xmlns:conv="using:LocoCalc.Converters"
             xmlns:ti="using:Avalonia.Input.TextInput"
             x:Class="LocoCalc.Views.MainView"
             x:DataType="vm:MainViewModel"
             Background="#0f0f1a">

  <UserControl.Resources>
    <conv:HexColorConverter    x:Key="HexColor"/>
    <conv:InverseBoolConverter x:Key="InvBool"/>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="ListBoxItem">
      <Setter Property="Padding"         Value="0"/>
      <Setter Property="Margin"          Value="0"/>
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ListBoxItem:focus /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <!-- Emoji font fallback for Android 16+ -->
    <Style Selector="TextBlock.emoji">
      <Setter Property="FontFamily" Value="{StaticResource EmojiFont}"/>
    </Style>
    <!-- Numeric keyboard on Android for all NumericUpDown inputs -->
    <Style Selector="NumericUpDown /template/ TextBox">
      <Setter Property="(ti:TextInputOptions.ContentType)" Value="Digits"/>
    </Style>
    <Style Selector="AutoCompleteBox">
      <Setter Property="ItemTemplate">
        <DataTemplate>
          <TextBlock Text="{Binding}" FontSize="16" Padding="4,8"/>
        </DataTemplate>
      </Setter>
    </Style>
  </UserControl.Styles>

  <Panel>
  <!-- Desktop layout: hidden on mobile -->
  <Grid RowDefinitions="Auto,Auto,*" x:Name="DesktopLayout">

    <!-- ═══ HEADER ═══════════════════════════════════════════════════════════ -->
    <Border Grid.Row="0" Background="#161626" BorderBrush="#2e2e50" BorderThickness="0,0,0,1" Padding="14,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <TextBlock Text="🚂" FontSize="22" VerticalAlignment="Center"/>
          <StackPanel Spacing="0">
            <TextBlock Text="LocoCalc" FontSize="20" FontWeight="Bold" Foreground="#f97316" LetterSpacing="1"/>
            <TextBlock Text="{Binding L.AppSubtitle}" FontSize="11" Foreground="#8888aa"/>
          </StackPanel>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <Border BorderBrush="#3a3a60" BorderThickness="0" CornerRadius="0" ClipToBounds="True">
            <StackPanel Orientation="Horizontal">
              <Button Content="🇨🇿" Padding="12,6" BorderThickness="0" CornerRadius="6"
                      FontSize="12" FontWeight="SemiBold" Foreground="White" Cursor="Hand"
                      Command="{Binding SetCzechCommand}">
                <Button.Background>
                  <Binding Path="IsCzech">
                    <Binding.Converter><conv:BoolToColorConverter TrueColor="#f97316" FalseColor="#252540"/></Binding.Converter>
                  </Binding>
                </Button.Background>
              </Button>
              <Button Content="🇬🇧" Padding="12,6" BorderThickness="0" CornerRadius="6"
                      FontSize="12" FontWeight="SemiBold" Foreground="White" Cursor="Hand"
                      Command="{Binding SetEnglishCommand}">
                <Button.Background>
                  <Binding Path="IsEnglish">
                    <Binding.Converter><conv:BoolToColorConverter TrueColor="#f97316" FalseColor="#252540"/></Binding.Converter>
                  </Binding>
                </Button.Background>
              </Button>
            </StackPanel>
          </Border>
          <Button Content="{Binding L.HistoryButton}"
                  Background="#252540" Foreground="#a0a0c0"
                  BorderBrush="#3a3a55" BorderThickness="1"
                  Padding="12,7" CornerRadius="8" FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                  Command="{Binding OpenHistoryDialogCommand}"/>
          <Button Background="#1e3a2e" Foreground="#22c55e"
                  BorderBrush="#22c55e" BorderThickness="1"
                  Padding="12,7" CornerRadius="8" FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                  IsEnabled="{Binding CanOpenTraction}"
                  Command="{Binding OpenTractionDialogCommand}">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="&#xF0D1;" FontFamily="{StaticResource FaFont}" FontSize="11" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding L.TwrButton}" FontSize="12" FontWeight="SemiBold"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ═══ BODY ══════════════════════════════════════════════════════════════ -->
    <Grid Grid.Row="2" ColumnDefinitions="270,*,220,265">

      <!-- ══════════════════════════════════════════════════════════════════════
           COL 0 — Loco catalogue
           ══════════════════════════════════════════════════════════════════════ -->
      <Border Grid.Column="0" Background="#161626" BorderBrush="#2e2e50" BorderThickness="0,0,1,0">
        <Grid RowDefinitions="Auto,*,Auto">

          <StackPanel Grid.Row="0" Spacing="6" Margin="10,10,10,6">
            <TextBlock Text="{Binding L.PanelLocos}" FontSize="10" FontWeight="Bold"
                       Foreground="#8888aa" LetterSpacing="1.5"/>
            <TextBox Text="{Binding SearchText}" Watermark="{Binding L.SearchPlaceholder}"
                     Background="#1e1e32" BorderBrush="#2e2e50" Foreground="#e8e8ff"
                     FontSize="12" CornerRadius="6" Padding="8,6"
                     IsTabStop="False"/>
          </StackPanel>

          <ListBox Grid.Row="1" Name="LocoListBox" x:Name="DesktopLocoListBox"
                   ItemsSource="{Binding LocoFlatList}"
                   Background="Transparent" BorderThickness="0" Padding="6,0,6,6"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   SelectionChanged="OnLocoListSelectionChanged"
                   DoubleTapped="OnLocoListDoubleTapped">
            <ListBox.ItemContainerTheme>
              <ControlTheme TargetType="ListBoxItem">
                <Setter Property="Padding"         Value="0"/>
                <Setter Property="Margin"          Value="0"/>
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                  <ControlTemplate>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"/>
                  </ControlTemplate>
                </Setter>
              </ControlTheme>
            </ListBox.ItemContainerTheme>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:LocoListItem">
                <Panel IsVisible="{Binding RowVisible}">

                  <!-- GROUP HEADER — Button so it's keyboard accessible too -->
                  <Button IsVisible="{Binding IsHeader}"
                          Background="Transparent" BorderThickness="0"
                          Padding="4,8,4,4" HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Left"
                          Command="{Binding $parent[UserControl].DataContext.ToggleGroupCommand}"
                          CommandParameter="{Binding Group}"
                          Cursor="Hand">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                      <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                               Fill="{Binding HeaderDotColor, Converter={StaticResource HexColor}}"/>
                      <TextBlock Text="{Binding HeaderLabel}" FontSize="10" FontWeight="Bold"
                                 Foreground="#8888aa" LetterSpacing="1" VerticalAlignment="Center"/>
                      <TextBlock Text="{Binding HeaderCount}" FontSize="10" Foreground="#555577"
                                 FontFamily="Consolas,monospace" VerticalAlignment="Center"/>
                      <TextBlock Text="{Binding ArrowText}" FontSize="12" Foreground="#555577"
                                 VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                  </Button>

                  <!-- LOCO ROW -->
                  <Border IsVisible="{Binding IsLoco}" CornerRadius="6" Padding="10,8"
                          Margin="0,2,0,0" BorderThickness="1" Cursor="Hand">
                    <Border.Styles>
                      <Style Selector="Border">
                        <Setter Property="Background"  Value="#1e1e32"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                      </Style>
                      <Style Selector="ListBoxItem:selected Border">
                        <Setter Property="Background"  Value="#221a0d"/>
                        <Setter Property="BorderBrush" Value="#f97316"/>
                      </Style>
                      <Style Selector="ListBoxItem:pointerover Border">
                        <Setter Property="BorderBrush" Value="#55f97316"/>
                      </Style>
                    </Border.Styles>
                    <StackPanel>
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding Loco.Designation}" FontSize="13"
                                   FontWeight="Medium" Foreground="#e8e8ff"/>
                        <Border Background="#2a1a08" CornerRadius="3" Padding="5,1"
                                IsVisible="{Binding Loco.HasEDB}">
                          <TextBlock Text="EDB" FontSize="10" FontWeight="Bold" Foreground="#f97316"/>
                        </Border>
                        <Border Background="#0a1a2a" CornerRadius="3" Padding="5,1"
                                IsVisible="{Binding Loco.HasRMode}">
                          <TextBlock Text="R" FontSize="10" FontWeight="Bold" Foreground="#3b82f6"/>
                        </Border>
                        <Border Background="#9400D3" CornerRadius="3" Padding="5, 1"
                                IsVisible="{Binding Loco.MultipleUnit}">
                          <TextBlock Text="VnŘ" FontSize="10" FontWeight="Bold" Foreground="#EE82EE"></TextBlock>
                        </Border>
                      </StackPanel>
                      <TextBlock FontSize="10" Foreground="#8888aa" Margin="0,2,0,0"
                                 FontFamily="Consolas,monospace">
                        <TextBlock.Text>
                          <MultiBinding StringFormat="{}{0} t · {1} t · {2} m · {3} km/h">
                            <Binding Path="Loco.TotalWeightTonnes"/>
                            <Binding Path="Loco.BrakingWeightTonnes"/>
                            <Binding Path="Loco.LengthM"/>
                            <Binding Path="Loco.MaxSpeed"/>
                          </MultiBinding>
                        </TextBlock.Text>
                      </TextBlock>
                    </StackPanel>
                  </Border>

                </Panel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <Border Grid.Row="2" Padding="10" BorderBrush="#2e2e50" BorderThickness="0,1,0,0">
            <Button Content="{Binding L.AddToConsist}"
                    Background="#f97316" Foreground="White" FontSize="14" FontWeight="Bold"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Padding="0,11" CornerRadius="8" IsEnabled="{Binding CanAddLoco}"
                    Command="{Binding AddLocoToConsistCommand}" Cursor="Hand"/>
          </Border>
        </Grid>
      </Border>

      <!-- ══════════════════════════════════════════════════════════════════════
           COL 1 — Consist builder
           ══════════════════════════════════════════════════════════════════════ -->
      <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto,Auto" Background="#0f0f1a">

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#161626" BorderBrush="#2e2e50" BorderThickness="0,0,0,1" Padding="10,8">
          <Grid ColumnDefinitions="*,Auto,Auto">
            <TextBox Grid.Column="0" Text="{Binding ConsistName}" Watermark="{Binding L.ConsistNamePh}"
                     Background="#1e1e32" BorderBrush="#2e2e50" Foreground="#e8e8ff"
                     FontSize="13" CornerRadius="6" Padding="10,7" Margin="0,0,8,0"
                     IsTabStop="False"/>
            <Button Grid.Column="1" Background="#3b82f6" Foreground="White"
                    FontSize="13" FontWeight="Bold" Padding="14,7" CornerRadius="6"
                    Margin="0,0,5,0" Command="{Binding SaveConsistCommand}" Cursor="Hand">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#xF0C7;" FontFamily="{StaticResource FaFont}"/>
                <TextBlock Text="{Binding L.SaveButton}"/>
              </StackPanel>
            </Button>
            <Button Grid.Column="2" Background="#1e1e32" Foreground="#8888aa"
                    FontSize="13" FontWeight="SemiBold" Padding="14,7" CornerRadius="6"
                    BorderBrush="#2e2e50" BorderThickness="1" Margin="0,0,5,0"
                    Command="{Binding NewConsistCommand}" Cursor="Hand">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="＋"/>
                <TextBlock Text="{Binding L.NewButton}"/>
              </StackPanel>
            </Button>
            <!-- StatusMessage moved to toast overlay -->
          </Grid>
        </Border>

        <!-- Consist entries -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="10,8" Spacing="5">
            <TextBlock Text="{Binding L.EmptyConsist}" Foreground="#8888aa" FontSize="13"
                       TextAlignment="Center" Margin="0,40" IsVisible="{Binding !ConsistEntries.Count}"/>
            <ItemsControl ItemsSource="{Binding ConsistEntries}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ConsistEntryViewModel">
                  <Border CornerRadius="8" Padding="12,10" Margin="0,0,0,4" BorderThickness="3,0,0,0">
                    <Border.Background><SolidColorBrush Color="#161626"/></Border.Background>
                    <Border.BorderBrush>
                      <Binding Path="EntryBorderColor" Converter="{StaticResource HexColor}"/>
                    </Border.BorderBrush>
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto">
                      <!-- Info -->
                      <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center"
                                  DoubleTapped="OnConsistEntryDoubleTapped" Cursor="Hand">
                        <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="Medium" Foreground="#e8e8ff"/>
                        <TextBlock Text="{Binding Designation}" FontSize="10" Foreground="#5555aa" FontStyle="Italic"
                                   IsVisible="{Binding HasCustomName}"/>
                        <TextBlock FontSize="10" Foreground="#8888aa" FontFamily="Consolas,monospace">
                          <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} t · {1} · {2} m">
                              <Binding Path="TotalWeightTonnes"/>
                              <Binding Path="ActiveBrakeDisplay"/>
                              <Binding Path="LengthM"/>
                            </MultiBinding>
                          </TextBlock.Text>
                        </TextBlock>
                      </StackPanel>
                      <!-- P/R mode toggle -->
                      <Button Grid.Column="1" Content="{Binding RModeButtonText}"
                              Foreground="White" FontSize="11" FontWeight="Bold"
                              FontFamily="Consolas,monospace" Padding="8,5" CornerRadius="5"
                              Margin="6,0" MinWidth="36" IsEnabled="{Binding HasRMode}"
                              Command="{Binding $parent[UserControl].DataContext.ToggleRModeCommand}"
                              CommandParameter="{Binding}" Cursor="Hand">
                        <Button.Background>
                          <Binding Path="RModeButtonColor" Converter="{StaticResource HexColor}"/>
                        </Button.Background>
                      </Button>
                      <!-- Brake toggle -->
                      <Button Grid.Column="2" Content="{Binding BrakesButtonText}"
                              Foreground="White" FontSize="11" FontWeight="Bold"
                              FontFamily="Consolas,monospace" Padding="8,5" CornerRadius="5"
                              Margin="0,0,4,0" MinWidth="62" IsEnabled="{Binding !BrakesLocked}"
                              Command="{Binding $parent[UserControl].DataContext.ToggleBrakesCommand}"
                              CommandParameter="{Binding}" Cursor="Hand">
                        <Button.Background>
                          <Binding Path="BrakesOnColor" Converter="{StaticResource HexColor}"/>
                        </Button.Background>
                      </Button>
                      <!-- EDB toggle -->
                      <Button Grid.Column="3" Content="{Binding EdbButtonText}"
                              Foreground="White" FontSize="11" FontWeight="Bold"
                              Padding="7,5" CornerRadius="5" Margin="0,0,4,0"
                              IsEnabled="{Binding EdbButtonEnabled}"
                              Command="{Binding $parent[UserControl].DataContext.ToggleEdbCommand}"
                              CommandParameter="{Binding}" Cursor="Hand">
                        <Button.Background>
                          <Binding Path="EdbButtonColor" Converter="{StaticResource HexColor}"/>
                        </Button.Background>
                      </Button>
                      <!-- IsTransported toggle (B column in ZoB) -->
                      <Button Grid.Column="4"
                              Foreground="White" FontSize="9" FontWeight="Bold"
                              Padding="5,5" CornerRadius="5" Margin="0,0,4,0"
                              Command="{Binding $parent[UserControl].DataContext.ToggleIsTransportedCommand}"
                              CommandParameter="{Binding}" Cursor="Hand"
                              ToolTip.Tip="Dopravovaná lokomotiva (sloupec B v ZoB)">
                        <Button.Background>
                          <Binding Path="IsTransported">
                            <Binding.Converter>
                              <conv:BoolToColorConverter TrueColor="#7c3aed" FalseColor="#252540"/>
                            </Binding.Converter>
                          </Binding>
                        </Button.Background>
                        <TextBlock Text="DOPR" FontSize="9" FontWeight="Bold"/>
                      </Button>
                      <!-- Move up/down -->
                      <StackPanel Grid.Column="5" Spacing="2" Margin="0,0,4,0">
                        <Button Content="↑" Background="#252540" Foreground="#e8e8ff" BorderThickness="0"
                                Width="22" Height="22" Padding="0" FontSize="11" CornerRadius="3"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                Command="{Binding $parent[UserControl].DataContext.MoveUpCommand}"
                                CommandParameter="{Binding}" Cursor="Hand"/>
                        <Button Content="↓" Background="#252540" Foreground="#e8e8ff" BorderThickness="0"
                                Width="22" Height="22" Padding="0" FontSize="11" CornerRadius="3"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                Command="{Binding $parent[UserControl].DataContext.MoveDownCommand}"
                                CommandParameter="{Binding}" Cursor="Hand"/>
                      </StackPanel>
                      <!-- Remove -->
                      <Button Grid.Column="6" Content="✕" Background="Transparent"
                              Foreground="#ef4444" BorderThickness="0" FontSize="16" Padding="3,0" Opacity="0.7"
                              Command="{Binding $parent[UserControl].DataContext.RemoveEntryCommand}"
                              CommandParameter="{Binding}" Cursor="Hand"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>

        <!-- Strip overview -->
        <Border Grid.Row="2" Background="#161626" BorderBrush="#2e2e50" BorderThickness="0,1,0,1" Padding="10,8">
          <StackPanel Spacing="5">
            <TextBlock Text="{Binding L.ConsistOverview}" FontSize="11" FontWeight="Bold"
                       Foreground="#8888aa" LetterSpacing="2"/>
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
              <ItemsControl ItemsSource="{Binding ConsistEntries}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="5"/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ConsistEntryViewModel">
                    <Border Background="#1e1e32" CornerRadius="5" Padding="8,6" MinWidth="78"
                            BorderThickness="0,0,0,3">
                      <Border.BorderBrush>
                        <Binding Path="EntryBorderColor" Converter="{StaticResource HexColor}"/>
                      </Border.BorderBrush>
                      <StackPanel HorizontalAlignment="Center" Spacing="2">
                        <Image Source="{Binding LocoImage}" Width="62" Height="36" Stretch="Uniform"
                               IsVisible="{Binding LocoImage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        <TextBlock Text="🚂" FontSize="14" TextAlignment="Center"
                                   IsVisible="{Binding LocoImage, Converter={x:Static ObjectConverters.IsNull}}"/>
                        <TextBlock Text="{Binding Designation}" FontSize="9" Foreground="#8888aa"
                                   TextAlignment="Center" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding PositionDisplay}" FontSize="9" FontWeight="SemiBold"
                                   TextAlignment="Center">
                          <TextBlock.Foreground>
                            <Binding Path="EntryBorderColor" Converter="{StaticResource HexColor}"/>
                          </TextBlock.Foreground>
                        </TextBlock>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </StackPanel>
        </Border>

        <!-- Stats bar -->
        <Border Grid.Row="3" Background="#161626" Padding="10,8">
          <Grid ColumnDefinitions="*,*,*,*,*">
            <Border Grid.Column="0" Background="#1e1e32" CornerRadius="6" Padding="8,7">
              <StackPanel>
                <TextBlock Text="{Binding L.StatLocos}" FontSize="9" FontWeight="Bold" Foreground="#8888aa" LetterSpacing="1"/>
                <TextBlock Text="{Binding ConsistEntries.Count}" FontSize="16" FontWeight="Bold"
                           Foreground="#e8e8ff" FontFamily="Consolas,monospace"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="#1e1e32" CornerRadius="6" Padding="8,7">
              <StackPanel>
                <TextBlock Text="{Binding L.ConsistTotalWeight}" FontSize="9" FontWeight="Bold" Foreground="#8888aa" LetterSpacing="1"/>
                <TextBlock Text="{Binding TotalWeightDisplay}" FontSize="16" FontWeight="Bold"
                           Foreground="#e8e8ff" FontFamily="Consolas,monospace"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="#1e1e32" CornerRadius="6" Padding="8,7">
              <StackPanel>
                <TextBlock Text="{Binding L.StatLength}" FontSize="9" FontWeight="Bold" Foreground="#8888aa" LetterSpacing="1"/>
                <TextBlock Text="{Binding TotalLengthDisplay}" FontSize="16" FontWeight="Bold"
                           Foreground="#e8e8ff" FontFamily="Consolas,monospace"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="3" Background="#1e1e32" CornerRadius="6" Padding="8,7">
              <StackPanel>
                <TextBlock Text="{Binding L.StatActiveBrake}" FontSize="9" FontWeight="Bold" Foreground="#8888aa" LetterSpacing="1"/>
                <TextBlock Text="{Binding ActiveBrakeWeightDisplay}" FontSize="16" FontWeight="Bold"
                           Foreground="#22c55e" FontFamily="Consolas,monospace"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="4" Background="#1e1e32" CornerRadius="6" Padding="8,7">
              <StackPanel>
                <TextBlock Text="{Binding L.ConsistBrakingPct}" FontSize="9" FontWeight="Bold" Foreground="#8888aa" LetterSpacing="1"/>
                <TextBlock Text="{Binding BrakingPercentageDisplay}" FontSize="16" FontWeight="Bold"
                           FontFamily="Consolas,monospace">
                  <TextBlock.Foreground>
                    <Binding Path="BrakingPercentageColor" Converter="{StaticResource HexColor}"/>
                  </TextBlock.Foreground>
                </TextBlock>
              </StackPanel>
            </Border>
          </Grid>
        </Border>
      </Grid>

      <!-- ══════════════════════════════════════════════════════════════════════
           COL 2 — Saved consists
           ══════════════════════════════════════════════════════════════════════ -->
      <Border Grid.Column="2" Background="#161626" BorderBrush="#2e2e50" BorderThickness="1,0,1,0">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0" Padding="10,10,10,6" BorderBrush="#2e2e50" BorderThickness="0,0,0,1">
            <TextBlock Text="{Binding L.SavedConsists}" FontSize="10" FontWeight="Bold"
                       Foreground="#8888aa" LetterSpacing="1.5"/>
          </Border>
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="6">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding L.NoSaved}" Foreground="#8888aa" FontSize="12"
                         Margin="4,10" IsVisible="{Binding !SavedConsists.Count}"/>
              <ItemsControl ItemsSource="{Binding SavedConsists}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:Consist">
                    <Border Background="#1e1e32" CornerRadius="8" Padding="10" Margin="0,2">
                      <StackPanel Spacing="5">
                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#e8e8ff"/>
                        <TextBlock FontSize="10" Foreground="#8888aa" FontFamily="Consolas,monospace">
                          <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} · {1:dd MMM HH:mm}">
                              <Binding Path="Entries.Count"/>
                              <Binding Path="LastModified"/>
                            </MultiBinding>
                          </TextBlock.Text>
                        </TextBlock>
                        <Grid ColumnDefinitions="*,Auto">
                          <Button Grid.Column="0"
                                  Content="{Binding $parent[UserControl].DataContext.L.LoadButton}"
                                  Background="#3b82f6" Foreground="White" FontSize="12" FontWeight="Bold"
                                  Padding="0,6" CornerRadius="5" HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Center" Margin="0,0,4,0"
                                  Command="{Binding $parent[UserControl].DataContext.LoadConsistCommand}"
                                  CommandParameter="{Binding}" Cursor="Hand"/>
                          <Button Grid.Column="1" Content="✕" Background="Transparent" Foreground="#ef4444"
                                  BorderBrush="#2e2e50" BorderThickness="1" Width="28" Height="28"
                                  Padding="0" FontSize="13" CornerRadius="5"
                                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                  Command="{Binding $parent[UserControl].DataContext.DeleteConsistCommand}"
                                  CommandParameter="{Binding}" Cursor="Hand"/>
                        </Grid>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- ══════════════════════════════════════════════════════════════════════
           COL 3 — ETCS panel
           ══════════════════════════════════════════════════════════════════════ -->
      <Border Grid.Column="3" Background="#161626" BorderBrush="#2e2e50" BorderThickness="1,0,0,0">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0" Padding="10,10,10,6" BorderBrush="#2e2e50" BorderThickness="0,0,0,1">
            <TextBlock Text="{Binding L.EtcsData}" FontSize="10" FontWeight="Bold"
                       Foreground="#8888aa" LetterSpacing="1.5"/>
          </Border>
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8,8" Spacing="7">

              <!-- Warning -->
              <Border Background="#3f1a0a" BorderBrush="#f97316" BorderThickness="1"
                      CornerRadius="6" Padding="10,9" IsVisible="{Binding EtcsWarningVisible}">
                <StackPanel Spacing="4">
                  <Grid ColumnDefinitions="18,*">
                    <TextBlock Grid.Column="0" Text="&#xF071;" FontFamily="{StaticResource FaFont}"
                               FontSize="11" Foreground="#fdba74"/>
                    <TextBlock Grid.Column="1" Text="{Binding EtcsWarningText}" FontSize="11"
                               Foreground="#fdba74" TextWrapping="Wrap" LineHeight="17"/>
                  </Grid>
                  <Grid ColumnDefinitions="18,*">
                    <TextBlock Grid.Column="0" Text="&#xF05E;" FontFamily="{StaticResource FaFont}"
                               FontSize="11" Foreground="#fdba74"/>
                    <TextBlock Grid.Column="1" Text="{Binding EtcsWarningSubText}" FontSize="11"
                               Foreground="#fdba74" TextWrapping="Wrap"/>
                  </Grid>
                </StackPanel>
              </Border>

              <!-- Speed -->
              <Border Background="#1e1e32" CornerRadius="8" Padding="11,9">
                <StackPanel Spacing="7">
                  <TextBlock Text="{Binding L.SpeedSection}" FontSize="9" FontWeight="Bold"
                             Foreground="#8888aa" LetterSpacing="1.5"/>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding L.SpeedLabel}" FontSize="12"
                               Foreground="#8888aa" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding EtcsDefSpeed, StringFormat='{}{0} km/h'}"
                               FontSize="15" FontWeight="Bold" Foreground="#f97316" FontFamily="Consolas,monospace"/>
                  </Grid>
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding L.SpeedOverride}" FontSize="11" Foreground="#8888aa"/>
                    <Grid ColumnDefinitions="*,Auto">
                      <NumericUpDown Grid.Column="0" Value="{Binding SpeedOverride}"
                                     Minimum="10" Maximum="200" Increment="10"
                                     Background="#252540" Foreground="#e8e8ff"
                                     BorderBrush="#3a3a60" CornerRadius="5"
                                     FormatString="0 km/h" FontSize="13"/>
                      <Button Grid.Column="1" Content="↺" Background="Transparent" Foreground="#8888aa"
                              BorderThickness="0" FontSize="14" Margin="4,0,0,0"
                              Command="{Binding ClearSpeedOverrideCommand}" Cursor="Hand"/>
                    </Grid>
                  </StackPanel>
                </StackPanel>
              </Border>

              <!-- Consist params -->
              <Border Background="#1e1e32" CornerRadius="8" Padding="11,9">
                <StackPanel Spacing="2">
                  <TextBlock Text="{Binding L.TrainParameters}" FontSize="9" FontWeight="Bold"
                             Foreground="#8888aa" LetterSpacing="1.5" Margin="0,0,0,5"/>
                  <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                    <TextBlock Grid.Column="0" Text="{Binding L.StatBrakingPct}" FontSize="12" Foreground="#8888aa"/>
                    <TextBlock Grid.Column="1" Text="{Binding BrakingPercentageDisplay}"
                               FontSize="14" FontWeight="Bold" FontFamily="Consolas,monospace">
                      <TextBlock.Foreground>
                        <Binding Path="BrakingPercentageColor" Converter="{StaticResource HexColor}"/>
                      </TextBlock.Foreground>
                    </TextBlock>
                  </Grid>
                  <Border Background="#2e2e50" Height="1"/>
                  <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                    <TextBlock Grid.Column="0" Text="{Binding L.StatTotalWeight}" FontSize="12" Foreground="#8888aa"/>
                    <TextBlock Grid.Column="1" Text="{Binding TotalWeightDisplay}"
                               FontSize="14" FontWeight="Bold" Foreground="#e8e8ff" FontFamily="Consolas,monospace"/>
                  </Grid>
                  <Border Background="#2e2e50" Height="1"/>
                  <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                    <TextBlock Grid.Column="0" Text="{Binding L.TrainLength}" FontSize="12" Foreground="#8888aa"/>
                    <TextBlock Grid.Column="1" Text="{Binding TotalLengthDisplay}"
                               FontSize="14" FontWeight="Bold" Foreground="#e8e8ff" FontFamily="Consolas,monospace"/>
                  </Grid>
                </StackPanel>
              </Border>

              <!-- ETCS box -->
              <Border Background="#252540" CornerRadius="8" Padding="11,9"
                      BorderBrush="#3a3a60" BorderThickness="1">
                <StackPanel Spacing="2">
                  <TextBlock Text="{Binding L.EtcsParameters}" FontSize="9" FontWeight="Bold"
                             Foreground="#8888aa" LetterSpacing="1.5" Margin="0,0,0,6"/>
                  <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                    <TextBlock Grid.Column="0" Text="{Binding L.CrossSection}" FontSize="12" Foreground="#8888aa"/>
                    <TextBlock Grid.Column="1" Text="GC" FontSize="14" FontWeight="Bold"
                               Foreground="#f97316" FontFamily="Consolas,monospace"/>
                  </Grid>
                  <Border Background="#2e2e50" Height="1"/>
                  <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                    <TextBlock Grid.Column="0" Text="{Binding L.CantDeficiency}" FontSize="12" Foreground="#8888aa"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5">
                      <TextBlock Text="{Binding EtcsFpClass}" FontSize="14" FontWeight="Bold"
                                 Foreground="#e8e8ff" FontFamily="Consolas,monospace"/>
                      <Border Background="#f97316" CornerRadius="3" Padding="5,1">
                        <TextBlock Text="{Binding EtcsFpMm, StringFormat='{}{0} mm'}"
                                   FontSize="11" FontWeight="Bold" Foreground="White" FontFamily="Consolas,monospace"/>
                      </Border>
                    </StackPanel>
                  </Grid>
                  <Border Background="#2e2e50" Height="1"/>
                  <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                    <TextBlock Grid.Column="0" Text="{Binding L.EtcsMaxSpeed}" FontSize="12" Foreground="#8888aa"/>
                    <TextBlock Grid.Column="1" Text="{Binding EtcsMaxSpeedDisplay}"
                               FontSize="14" FontWeight="Bold" Foreground="#f97316" FontFamily="Consolas,monospace"/>
                  </Grid>
                  <Border Background="#2e2e50" Height="1"/>
                  <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                    <TextBlock Grid.Column="0" Text="{Binding L.BrakingPctLabel}" FontSize="12" Foreground="#8888aa"/>
                    <TextBlock Grid.Column="1" Text="{Binding BrakingPercentageDisplay}"
                               FontSize="14" FontWeight="Bold" FontFamily="Consolas,monospace">
                      <TextBlock.Foreground>
                        <Binding Path="EtcsBrakingColor" Converter="{StaticResource HexColor}"/>
                      </TextBlock.Foreground>
                    </TextBlock>
                  </Grid>
                  <Border Background="#2e2e50" Height="1"/>
                  <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                    <TextBlock Grid.Column="0" Text="{Binding L.TrainLength}" FontSize="12" Foreground="#8888aa"/>
                    <TextBlock Grid.Column="1" Text="{Binding TotalLengthDisplay}"
                               FontSize="14" FontWeight="Bold" Foreground="#e8e8ff" FontFamily="Consolas,monospace"/>
                  </Grid>
                  <Border Background="#2e2e50" Height="1"/>
                  <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                    <TextBlock Grid.Column="0" Text="{Binding L.AxleLoad}" FontSize="12" Foreground="#8888aa"/>
                    <TextBlock Grid.Column="1" Text="{Binding EtcsAxleLoad}"
                               FontSize="14" FontWeight="Bold" Foreground="#f97316" FontFamily="Consolas,monospace"/>
                  </Grid>
                </StackPanel>
              </Border>

              <!-- Station pickers -->
              <StackPanel Spacing="6">
                <TextBlock Text="{Binding L.StartStation}" FontSize="10" FontWeight="Bold"
                           Foreground="#8888aa" LetterSpacing="1"/>
                <AutoCompleteBox x:Name="StartStationBox"
                                 ItemsSource="{Binding AllStations}"
                                 SelectedItem="{Binding StartStation, Mode=TwoWay}"
                                 FilterMode="Custom"
                                 MinimumPrefixLength="2"
                                 Watermark="{Binding L.StartStationPh}"
                                 Background="#1a1a2e" Foreground="#e8e8ff"
                                 BorderBrush="#3a3a60" CornerRadius="5" FontSize="12"/>
                <TextBlock Text="{Binding L.EndStation}" FontSize="10" FontWeight="Bold"
                           Foreground="#8888aa" LetterSpacing="1"/>
                <AutoCompleteBox x:Name="EndStationBox"
                                 ItemsSource="{Binding AllStations}"
                                 SelectedItem="{Binding EndStation, Mode=TwoWay}"
                                 FilterMode="Custom"
                                 MinimumPrefixLength="2"
                                 Watermark="{Binding L.EndStationPh}"
                                 Background="#1a1a2e" Foreground="#e8e8ff"
                                 BorderBrush="#3a3a60" CornerRadius="5" FontSize="12"/>
              </StackPanel>

              <!-- Required braking % -->
              <TextBlock Text="POTŘEBNÁ BRZDÍCÍ %" FontSize="10" FontWeight="Bold"
                         Foreground="#8888aa" LetterSpacing="1"/>
              <TextBox Text="{Binding RequiredBrakingPct}"
                       Watermark="např. 65"
                       Background="#1a1a2e" Foreground="#e8e8ff"
                       BorderBrush="#3a3a60" CornerRadius="5" FontSize="12"/>

              <!-- ZoB button -->
              <Button Background="#059669" Foreground="White"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                      Padding="0,11" CornerRadius="8"
                      Command="{Binding GenerateZoBCommand}" Cursor="Hand">
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <TextBlock Text="&#xF1C1;" FontFamily="{StaticResource FaFont}" FontSize="13"/>
                  <TextBlock Text="Generovat ZoB" FontSize="13" FontWeight="Bold"/>
                </StackPanel>
              </Button>

              <!-- FP legend -->
              <TextBlock FontSize="10" Foreground="#8888aa" TextWrapping="Wrap" Margin="1,0" LineHeight="17">FP3 (130 mm): 163, 186, 189, 363, 363.5, 372, 383, 386, 388, 393<LineBreak/>FP2 (100 mm): ostatní řady</TextBlock>

            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>

    </Grid><!-- /body -->

  </Grid>

  <!-- ═══ MOBILE LAYOUT ══════════════════════════════════════════════════ -->
  <!-- Shown on mobile (narrow), hidden on desktop — toggled from code-behind -->
  <Grid x:Name="MobileLayout" RowDefinitions="Auto,Auto,*,Auto" IsVisible="False">

    <!-- Mobile header -->
    <Border Grid.Row="0" Background="#161626" BorderBrush="#2e2e50" BorderThickness="0,0,0,1" Padding="14,14">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="🚂" FontSize="22" VerticalAlignment="Center" FontFamily="{StaticResource EmojiFont}" Margin="0,1,0,0"/>
          <TextBlock Text="LocoCalc" FontSize="22" FontWeight="Bold" Foreground="#f97316"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Mobile content area — swaps between tabs -->
    <Grid Grid.Row="2" Background="#0f0f1a">

      <!-- ── TAB: CONSIST ───────────────────────────────────────────────── -->
      <Grid RowDefinitions="*,Auto,Auto" IsVisible="{Binding MobileTabConsist}">
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="10,8" Spacing="5">
            <TextBlock Text="{Binding L.EmptyConsistMobile}" Foreground="#8888aa" FontSize="13"
                       TextAlignment="Center" Margin="0,40" IsVisible="{Binding !ConsistEntries.Count}"/>
            <ItemsControl ItemsSource="{Binding ConsistEntries}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ConsistEntryViewModel">
                  <Border CornerRadius="8" Padding="10,9" Margin="0,0,0,4" BorderThickness="3,0,0,0">
                    <Border.Background><SolidColorBrush Color="#161626"/></Border.Background>
                    <Border.BorderBrush>
                      <Binding Path="EntryBorderColor" Converter="{StaticResource HexColor}"/>
                    </Border.BorderBrush>

                    <!-- 3-column layout: info | context panel | ⋮ menu toggle -->
                    <Grid ColumnDefinitions="*,Auto,Auto">

                      <!-- Col 0: loco info + rename button -->
                      <Grid Grid.Column="0" ColumnDefinitions="*,Auto" Margin="0,0,6,0">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center"
                                    DoubleTapped="OnConsistEntryDoubleTapped" Cursor="Hand">
                          <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="Medium" Foreground="#e8e8ff"/>
                          <TextBlock Text="{Binding Designation}" FontSize="10" Foreground="#5555aa" FontStyle="Italic"
                                     IsVisible="{Binding HasCustomName}"/>
                          <TextBlock FontSize="10" Foreground="#8888aa" FontFamily="Consolas,monospace">
                            <TextBlock.Text>
                              <MultiBinding StringFormat="{}{0} t · {1} · {2} m">
                                <Binding Path="TotalWeightTonnes"/>
                                <Binding Path="ActiveBrakeDisplay"/>
                                <Binding Path="LengthM"/>
                              </MultiBinding>
                            </TextBlock.Text>
                          </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="1" Content="ℹ" Background="#1a2a40" Foreground="#3b82f6"
                                BorderBrush="#3b82f6" BorderThickness="1"
                                Width="32" Height="32" Padding="0" FontSize="15" CornerRadius="6"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                VerticalAlignment="Center"
                                Command="{Binding $parent[UserControl].DataContext.OpenRenameDialogCommand}"
                                CommandParameter="{Binding}" Cursor="Hand"/>
                      </Grid>

                      <!-- Col 1: context panel — loco controls OR position/delete controls -->

                      <!-- Loco controls (default, hidden when ShowPositionControls) -->
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="3" Margin="0,0,3,0"
                                  IsVisible="{Binding !ShowPositionControls}">
                        <Button Content="{Binding RModeButtonText}"
                                Foreground="White" FontSize="10" FontWeight="Bold"
                                FontFamily="Consolas,monospace" Height="44" Padding="7,0" CornerRadius="6"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                MinWidth="44" IsEnabled="{Binding HasRMode}"
                                Command="{Binding $parent[UserControl].DataContext.ToggleRModeCommand}"
                                CommandParameter="{Binding}" Cursor="Hand">
                          <Button.Background>
                            <Binding Path="RModeButtonColor" Converter="{StaticResource HexColor}"/>
                          </Button.Background>
                        </Button>
                        <Button Content="{Binding BrakesButtonText}"
                                Foreground="White" FontSize="10" FontWeight="Bold"
                                FontFamily="Consolas,monospace" Height="44" Padding="7,0" CornerRadius="6"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                MinWidth="52" IsEnabled="{Binding !BrakesLocked}"
                                Command="{Binding $parent[UserControl].DataContext.ToggleBrakesCommand}"
                                CommandParameter="{Binding}" Cursor="Hand">
                          <Button.Background>
                            <Binding Path="BrakesOnColor" Converter="{StaticResource HexColor}"/>
                          </Button.Background>
                        </Button>
                        <Button Content="{Binding EdbButtonText}"
                                Foreground="White" FontSize="10" FontWeight="Bold"
                                Height="44" Padding="6,0" CornerRadius="6"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                IsEnabled="{Binding EdbButtonEnabled}"
                                Command="{Binding $parent[UserControl].DataContext.ToggleEdbCommand}"
                                CommandParameter="{Binding}" Cursor="Hand">
                          <Button.Background>
                            <Binding Path="EdbButtonColor" Converter="{StaticResource HexColor}"/>
                          </Button.Background>
                        </Button>
                        <Button Foreground="White" FontSize="10" FontWeight="Bold"
                                Height="44" Width="52" Padding="0" CornerRadius="6"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                Command="{Binding $parent[UserControl].DataContext.ToggleIsTransportedCommand}"
                                CommandParameter="{Binding}" Cursor="Hand"
                                ToolTip.Tip="Dopravovaná lokomotiva (sloupec B v ZoB)">
                          <Button.Background>
                            <Binding Path="IsTransported">
                              <Binding.Converter>
                                <conv:BoolToColorConverter TrueColor="#7c3aed" FalseColor="#252540"/>
                              </Binding.Converter>
                            </Binding>
                          </Button.Background>
                          <TextBlock Text="DOPR" FontSize="10" FontWeight="Bold"/>
                        </Button>
                      </StackPanel>

                      <!-- Position / delete controls (shown when ShowPositionControls) -->
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="3" Margin="0,0,3,0"
                                  IsVisible="{Binding ShowPositionControls}">
                        <Button Content="↑" Background="#252540" Foreground="#e8e8ff" BorderThickness="0"
                                Width="44" Height="44" Padding="0" FontSize="18" CornerRadius="6"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                Command="{Binding $parent[UserControl].DataContext.MoveUpCommand}"
                                CommandParameter="{Binding}" Cursor="Hand"/>
                        <Button Content="↓" Background="#252540" Foreground="#e8e8ff" BorderThickness="0"
                                Width="44" Height="44" Padding="0" FontSize="18" CornerRadius="6"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                Command="{Binding $parent[UserControl].DataContext.MoveDownCommand}"
                                CommandParameter="{Binding}" Cursor="Hand"/>
                        <Button Content="✕" Background="#ef4444"
                                Foreground="White" BorderThickness="0" FontSize="20"
                                Width="44" Height="44" Padding="0" CornerRadius="6"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                Command="{Binding $parent[UserControl].DataContext.RemoveEntryCommand}"
                                CommandParameter="{Binding}" Cursor="Hand"/>
                      </StackPanel>

                      <!-- Col 2: menu toggle button (always visible) -->
                      <Button Grid.Column="2" Content="⋮"
                              Foreground="#aaaacc" BorderThickness="0"
                              Width="36" Height="44" Padding="0" FontSize="20" CornerRadius="6"
                              HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                              Command="{Binding ToggleMenuModeCommand}" Cursor="Hand">
                        <Button.Background>
                          <Binding Path="ShowPositionControls">
                            <Binding.Converter>
                              <conv:BoolToColorConverter TrueColor="#2a2a50" FalseColor="#1a1a30"/>
                            </Binding.Converter>
                          </Binding>
                        </Button.Background>
                      </Button>

                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>

        <!-- Consist strip -->
        <Border Grid.Row="1" Background="#161626" BorderBrush="#2e2e50" BorderThickness="0,1,0,1" Padding="8,6">
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding L.ConsistOverview}" FontSize="9" FontWeight="Bold"
                       Foreground="#8888aa" LetterSpacing="2"/>
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
              <ItemsControl ItemsSource="{Binding ConsistEntries}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="4"/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ConsistEntryViewModel">
                    <Border Background="#1e1e32" CornerRadius="6" Padding="10,8" MinWidth="88" BorderThickness="0,0,0,3">
                      <Border.BorderBrush>
                        <Binding Path="EntryBorderColor" Converter="{StaticResource HexColor}"/>
                      </Border.BorderBrush>
                      <StackPanel HorizontalAlignment="Center" Spacing="2">
                        <Image Source="{Binding LocoImage}" Width="68" Height="40" Stretch="Uniform"
                               IsVisible="{Binding LocoImage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        <TextBlock Text="🚂" FontSize="16" TextAlignment="Center"
                                   FontFamily="{StaticResource EmojiFont}" Margin="0,1,0,0"
                                   IsVisible="{Binding LocoImage, Converter={x:Static ObjectConverters.IsNull}}"/>
                        <TextBlock Text="{Binding Designation}" FontSize="10" Foreground="#8888aa"
                                   TextAlignment="Center" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding PositionDisplay}" FontSize="10" FontWeight="SemiBold"
                                   TextAlignment="Center">
                          <TextBlock.Foreground>
                            <Binding Path="EntryBorderColor" Converter="{StaticResource HexColor}"/>
                          </TextBlock.Foreground>
                        </TextBlock>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </StackPanel>
        </Border>

        <!-- Stats bar -->
        <Border Grid.Row="2" Background="#161626" Padding="8,6">
          <Grid ColumnDefinitions="*,*,*,*,*">
            <Border Grid.Column="0" Background="#1e1e32" CornerRadius="5" Padding="6,5" Margin="0,0,3,0">
              <StackPanel>
                <TextBlock Text="{Binding L.StatLocos}" FontSize="8" FontWeight="Bold" Foreground="#8888aa"/>
                <TextBlock Text="{Binding ConsistEntries.Count}" FontSize="14" FontWeight="Bold"
                           Foreground="#e8e8ff" FontFamily="Consolas,monospace"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="#1e1e32" CornerRadius="5" Padding="6,5" Margin="0,0,3,0">
              <StackPanel>
                <TextBlock Text="{Binding L.StatTotalWeight}" FontSize="8" FontWeight="Bold" Foreground="#8888aa"/>
                <TextBlock Text="{Binding TotalWeightDisplay}" FontSize="14" FontWeight="Bold"
                           Foreground="#e8e8ff" FontFamily="Consolas,monospace"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="#1e1e32" CornerRadius="5" Padding="6,5" Margin="0,0,3,0">
              <StackPanel>
                <TextBlock Text="{Binding L.StatLength}" FontSize="8" FontWeight="Bold" Foreground="#8888aa"/>
                <TextBlock Text="{Binding TotalLengthDisplay}" FontSize="14" FontWeight="Bold"
                           Foreground="#e8e8ff" FontFamily="Consolas,monospace"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="3" Background="#1e1e32" CornerRadius="5" Padding="6,5" Margin="0,0,3,0">
              <StackPanel>
                <TextBlock Text="{Binding L.StatActiveBrake}" FontSize="8" FontWeight="Bold" Foreground="#8888aa"/>
                <TextBlock Text="{Binding ActiveBrakeWeightDisplay}" FontSize="14" FontWeight="Bold"
                           Foreground="#22c55e" FontFamily="Consolas,monospace"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="4" Background="#1e1e32" CornerRadius="5" Padding="6,5">
              <StackPanel>
                <TextBlock Text="{Binding L.StatBrakingPct}" FontSize="8" FontWeight="Bold" Foreground="#8888aa"/>
                <TextBlock Text="{Binding BrakingPercentageDisplay}" FontSize="14" FontWeight="Bold"
                           FontFamily="Consolas,monospace">
                  <TextBlock.Foreground>
                    <Binding Path="BrakingPercentageColor" Converter="{StaticResource HexColor}"/>
                  </TextBlock.Foreground>
                </TextBlock>
              </StackPanel>
            </Border>
          </Grid>
        </Border>
      </Grid>

      <!-- ── TAB: ADD LOCO ──────────────────────────────────────────────── -->
      <Grid RowDefinitions="Auto,*,Auto" IsVisible="{Binding MobileTabAddLoco}">
        <StackPanel Grid.Row="0" Spacing="6" Margin="10,10,10,6">
          <TextBlock Text="{Binding L.PanelLocos}" FontSize="10" FontWeight="Bold"
                     Foreground="#8888aa" LetterSpacing="1.5"/>
          <TextBox Text="{Binding SearchText}" Watermark="{Binding L.SearchPlaceholder}"
                   Background="#1e1e32" BorderBrush="#2e2e50" Foreground="#e8e8ff"
                   FontSize="12" CornerRadius="6" Padding="8,6"
                   IsTabStop="False"/>
        </StackPanel>

        <ListBox Grid.Row="1" Name="MobileLocoListBox"
                 ItemsSource="{Binding LocoFlatList}"
                 Background="Transparent" BorderThickness="0" Padding="6,0,6,6"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 SelectionChanged="OnLocoListSelectionChanged"
                 DoubleTapped="OnLocoListDoubleTapped">
          <ListBox.ItemContainerTheme>
            <ControlTheme TargetType="ListBoxItem">
              <Setter Property="Padding"         Value="0"/>
              <Setter Property="Margin"          Value="0"/>
              <Setter Property="Background"      Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Template">
                <ControlTemplate>
                  <ContentPresenter Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"/>
                </ControlTemplate>
              </Setter>
            </ControlTheme>
          </ListBox.ItemContainerTheme>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:LocoListItem">
              <Panel IsVisible="{Binding RowVisible}">
                <Button IsVisible="{Binding IsHeader}"
                        Background="Transparent" BorderThickness="0"
                        Padding="4,8,4,4" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Command="{Binding $parent[UserControl].DataContext.ToggleGroupCommand}"
                        CommandParameter="{Binding Group}" Cursor="Hand">
                  <StackPanel Orientation="Horizontal" Spacing="7">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{Binding HeaderDotColor, Converter={StaticResource HexColor}}"/>
                    <TextBlock Text="{Binding HeaderLabel}" FontSize="10" FontWeight="Bold"
                               Foreground="#8888aa" LetterSpacing="1" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding HeaderCount}" FontSize="10" Foreground="#555577"
                               FontFamily="Consolas,monospace" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ArrowText}" FontSize="12" Foreground="#555577"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                  </StackPanel>
                </Button>
                <Border IsVisible="{Binding IsLoco}" CornerRadius="6" Padding="10,8"
                        Margin="0,2,0,0" BorderThickness="1" Cursor="Hand">
                  <Border.Styles>
                    <Style Selector="Border">
                      <Setter Property="Background"  Value="#1e1e32"/>
                      <Setter Property="BorderBrush" Value="Transparent"/>
                    </Style>
                    <Style Selector="ListBoxItem:selected Border">
                      <Setter Property="Background"  Value="#221a0d"/>
                      <Setter Property="BorderBrush" Value="#f97316"/>
                    </Style>
                    <Style Selector="ListBoxItem:pointerover Border">
                      <Setter Property="BorderBrush" Value="#55f97316"/>
                    </Style>
                  </Border.Styles>
                  <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{Binding Loco.Designation}" FontSize="13"
                                 FontWeight="Medium" Foreground="#e8e8ff"/>
                      <Border Background="#2a1a08" CornerRadius="3" Padding="5,1"
                              IsVisible="{Binding Loco.HasEDB}">
                        <TextBlock Text="EDB" FontSize="10" FontWeight="Bold" Foreground="#f97316"/>
                      </Border>
                      <Border Background="#0a1a2a" CornerRadius="3" Padding="5,1"
                              IsVisible="{Binding Loco.HasRMode}">
                        <TextBlock Text="R" FontSize="10" FontWeight="Bold" Foreground="#3b82f6"/>
                      </Border>
                      <Border Background="#9400D3" CornerRadius="3" Padding="5, 1"
                              IsVisible="{Binding Loco.MultipleUnit}">
                        <TextBlock Text="VnŘ" FontSize="10" FontWeight="Bold" Foreground="#EE82EE"></TextBlock>
                      </Border>
                    </StackPanel>
                    <TextBlock FontSize="10" Foreground="#8888aa" Margin="0,2,0,0"
                               FontFamily="Consolas,monospace">
                      <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} t · {1} t · {2} m · {3} km/h">
                          <Binding Path="Loco.TotalWeightTonnes"/>
                          <Binding Path="Loco.BrakingWeightTonnes"/>
                          <Binding Path="Loco.LengthM"/>
                          <Binding Path="Loco.MaxSpeed"/>
                        </MultiBinding>
                      </TextBlock.Text>
                    </TextBlock>
                  </StackPanel>
                </Border>
              </Panel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="2" Padding="10" BorderBrush="#2e2e50" BorderThickness="0,1,0,0">
          <Button Content="{Binding L.AddToConsist}"
                  Background="#f97316" Foreground="White" FontSize="14" FontWeight="Bold"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                  Padding="0,12" CornerRadius="8" IsEnabled="{Binding CanAddLoco}"
                  Command="{Binding AddLocoToConsistCommand}" Cursor="Hand"/>
        </Border>
      </Grid>

      <!-- ── TAB: ETCS ──────────────────────────────────────────────────── -->
      <ScrollViewer IsVisible="{Binding MobileTabEtcs}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10,10" Spacing="7">
          <Border Background="#3f1a0a" BorderBrush="#f97316" BorderThickness="1"
                  CornerRadius="6" Padding="10,9" IsVisible="{Binding EtcsWarningVisible}">
            <StackPanel Spacing="4">
              <Grid ColumnDefinitions="18,*">
                <TextBlock Grid.Column="0" Text="&#xF071;" FontFamily="{StaticResource FaFont}"
                           FontSize="11" Foreground="#fdba74"/>
                <TextBlock Grid.Column="1" Text="{Binding EtcsWarningText}" FontSize="11"
                           Foreground="#fdba74" TextWrapping="Wrap" LineHeight="17"/>
              </Grid>
              <Grid ColumnDefinitions="18,*">
                <TextBlock Grid.Column="0" Text="&#xF05E;" FontFamily="{StaticResource FaFont}"
                           FontSize="11" Foreground="#fdba74"/>
                <TextBlock Grid.Column="1" Text="{Binding EtcsWarningSubText}" FontSize="11"
                           Foreground="#fdba74" TextWrapping="Wrap"/>
              </Grid>
            </StackPanel>
          </Border>
          <Border Background="#1e1e32" CornerRadius="8" Padding="11,9">
            <StackPanel Spacing="7">
              <TextBlock Text="{Binding L.SpeedSection}" FontSize="9" FontWeight="Bold"
                         Foreground="#8888aa" LetterSpacing="1.5"/>
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding L.SpeedLabel}" FontSize="12"
                           Foreground="#8888aa" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding EtcsDefSpeed, StringFormat='{}{0} km/h'}"
                           FontSize="15" FontWeight="Bold" Foreground="#f97316" FontFamily="Consolas,monospace"/>
              </Grid>
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding L.SpeedOverride}" FontSize="11" Foreground="#8888aa"/>
                <Grid ColumnDefinitions="*,Auto">
                  <NumericUpDown Grid.Column="0" Value="{Binding SpeedOverride}"
                                 Minimum="10" Maximum="200" Increment="10"
                                 Background="#252540" Foreground="#e8e8ff"
                                 BorderBrush="#3a3a60" CornerRadius="5"
                                 FormatString="0 km/h" FontSize="13"/>
                  <Button Grid.Column="1" Content="↺" Background="Transparent" Foreground="#8888aa"
                          BorderThickness="0" FontSize="14" Margin="4,0,0,0"
                          Command="{Binding ClearSpeedOverrideCommand}" Cursor="Hand"/>
                </Grid>
              </StackPanel>
            </StackPanel>
          </Border>
          <Border Background="#252540" CornerRadius="8" Padding="11,9" BorderBrush="#3a3a60" BorderThickness="1">
            <StackPanel Spacing="2">
              <TextBlock Text="{Binding L.EtcsParameters}" FontSize="9" FontWeight="Bold"
                         Foreground="#8888aa" LetterSpacing="1.5" Margin="0,0,0,6"/>
              <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                <TextBlock Grid.Column="0" Text="{Binding L.CrossSection}" FontSize="12" Foreground="#8888aa"/>
                <TextBlock Grid.Column="1" Text="GC" FontSize="14" FontWeight="Bold"
                           Foreground="#f97316" FontFamily="Consolas,monospace"/>
              </Grid>
              <Border Background="#2e2e50" Height="1"/>
              <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                <TextBlock Grid.Column="0" Text="{Binding L.CantDeficiency}" FontSize="12" Foreground="#8888aa"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5">
                  <TextBlock Text="{Binding EtcsFpClass}" FontSize="14" FontWeight="Bold"
                             Foreground="#e8e8ff" FontFamily="Consolas,monospace"/>
                  <Border Background="#f97316" CornerRadius="3" Padding="5,1">
                    <TextBlock Text="{Binding EtcsFpMm, StringFormat='{}{0} mm'}"
                               FontSize="11" FontWeight="Bold" Foreground="White" FontFamily="Consolas,monospace"/>
                  </Border>
                </StackPanel>
              </Grid>
              <Border Background="#2e2e50" Height="1"/>
              <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                <TextBlock Grid.Column="0" Text="{Binding L.EtcsMaxSpeed}" FontSize="12" Foreground="#8888aa"/>
                <TextBlock Grid.Column="1" Text="{Binding EtcsMaxSpeedDisplay}"
                           FontSize="14" FontWeight="Bold" Foreground="#f97316" FontFamily="Consolas,monospace"/>
              </Grid>
              <Border Background="#2e2e50" Height="1"/>
              <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                <TextBlock Grid.Column="0" Text="{Binding L.BrakingPctLabel}" FontSize="12" Foreground="#8888aa"/>
                <TextBlock Grid.Column="1" Text="{Binding BrakingPercentageDisplay}"
                           FontSize="14" FontWeight="Bold" FontFamily="Consolas,monospace">
                  <TextBlock.Foreground>
                    <Binding Path="EtcsBrakingColor" Converter="{StaticResource HexColor}"/>
                  </TextBlock.Foreground>
                </TextBlock>
              </Grid>
              <Border Background="#2e2e50" Height="1"/>
              <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                <TextBlock Grid.Column="0" Text="{Binding L.TrainLength}" FontSize="12" Foreground="#8888aa"/>
                <TextBlock Grid.Column="1" Text="{Binding TotalLengthDisplay}"
                           FontSize="14" FontWeight="Bold" Foreground="#e8e8ff" FontFamily="Consolas,monospace"/>
              </Grid>
              <Border Background="#2e2e50" Height="1"/>
              <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                <TextBlock Grid.Column="0" Text="{Binding L.AxleLoad}" FontSize="12" Foreground="#8888aa"/>
                <TextBlock Grid.Column="1" Text="{Binding EtcsAxleLoad}"
                           FontSize="14" FontWeight="Bold" Foreground="#f97316" FontFamily="Consolas,monospace"/>
              </Grid>
            </StackPanel>
          </Border>
          <!-- Required braking % (mobile) -->
          <StackPanel Spacing="4">
            <TextBlock Text="POTŘEBNÁ BRZDÍCÍ %" FontSize="10" FontWeight="Bold"
                       Foreground="#8888aa" LetterSpacing="1"/>
            <TextBox Text="{Binding RequiredBrakingPct}"
                     Watermark="např. 65"
                     Background="#1e1e32" Foreground="#e8e8ff"
                     BorderBrush="#2e2e50" CornerRadius="6" FontSize="13"/>
          </StackPanel>

          <!-- ZoB button (mobile) -->
          <Button Background="#059669" Foreground="White"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                  Padding="0,13" CornerRadius="8"
                  Command="{Binding GenerateZoBCommand}" Cursor="Hand">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="&#xF1C1;" FontFamily="{StaticResource FaFont}" FontSize="14"/>
              <TextBlock Text="Generovat ZoB" FontSize="14" FontWeight="Bold"/>
            </StackPanel>
          </Button>
          <TextBlock FontSize="10" Foreground="#8888aa" TextWrapping="Wrap" Margin="1,0" LineHeight="17">FP3 (130 mm): 163, 186, 189, 363, 363.5, 372, 383, 386, 388, 393<LineBreak/>FP2 (100 mm): ostatní řady</TextBlock>
        </StackPanel>
      </ScrollViewer>

      <!-- ── TAB: MENU ──────────────────────────────────────────────────── -->
      <ScrollViewer IsVisible="{Binding MobileTabMenu}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,12" Spacing="10">

          <!-- Consist name -->
          <TextBlock Text="{Binding L.MenuConsistInfo}" FontSize="10" FontWeight="Bold"
                     Foreground="#8888aa" LetterSpacing="1.5" Margin="0,0,0,4"/>
          <TextBox Text="{Binding ConsistName}" Watermark="{Binding L.ConsistNamePh}"
                   Background="#1e1e32" BorderBrush="#2e2e50" Foreground="#e8e8ff"
                   FontSize="13" CornerRadius="6" Padding="10,9"
                   IsTabStop="False"/>

          <Border Background="#2e2e50" Height="1"/>

          <!-- Consist actions -->
          <Button Background="#3b82f6" Foreground="White"
                  FontSize="14" FontWeight="Bold" HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center" Padding="0,12" CornerRadius="8"
                  Command="{Binding SaveConsistCommand}" Cursor="Hand">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="&#xF0C7;" FontFamily="{StaticResource FaFont}"/>
              <TextBlock Text="{Binding L.SaveButton}"/>
            </StackPanel>
          </Button>
          <Button Background="#1e1e32" Foreground="#8888aa"
                  FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center" Padding="0,12" CornerRadius="8"
                  BorderBrush="#2e2e50" BorderThickness="1"
                  Command="{Binding NewConsistCommand}" Cursor="Hand">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="＋"/>
              <TextBlock Text="{Binding L.NewButton}"/>
            </StackPanel>
          </Button>

          <Border Background="#2e2e50" Height="1"/>

          <!-- Station pickers -->
          <TextBlock Text="{Binding L.StartStation}" FontSize="10" FontWeight="Bold"
                     Foreground="#8888aa" LetterSpacing="1.5" Margin="0,0,0,2"/>
          <AutoCompleteBox x:Name="StartStationBoxMobile"
                           ItemsSource="{Binding AllStations}"
                           SelectedItem="{Binding StartStation, Mode=TwoWay}"
                           FilterMode="Custom"
                           MinimumPrefixLength="2"
                           Watermark="{Binding L.StartStationPh}"
                           Background="#1e1e32" Foreground="#e8e8ff"
                           BorderBrush="#2e2e50" CornerRadius="6" FontSize="13"/>
          <TextBlock Text="{Binding L.EndStation}" FontSize="10" FontWeight="Bold"
                     Foreground="#8888aa" LetterSpacing="1.5" Margin="0,0,0,2"/>
          <AutoCompleteBox x:Name="EndStationBoxMobile"
                           ItemsSource="{Binding AllStations}"
                           SelectedItem="{Binding EndStation, Mode=TwoWay}"
                           FilterMode="Custom"
                           MinimumPrefixLength="2"
                           Watermark="{Binding L.EndStationPh}"
                           Background="#1e1e32" Foreground="#e8e8ff"
                           BorderBrush="#2e2e50" CornerRadius="6" FontSize="13"/>

          <Border Background="#2e2e50" Height="1"/>

          <!-- Saved consists -->
          <TextBlock Text="{Binding L.MenuSaved}" FontSize="10" FontWeight="Bold"
                     Foreground="#8888aa" LetterSpacing="1.5" Margin="0,0,0,4"/>
          <TextBlock Text="{Binding L.NoSaved}" Foreground="#8888aa" FontSize="12"
                     IsVisible="{Binding !SavedConsists.Count}"/>
          <ItemsControl ItemsSource="{Binding SavedConsists}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:Consist">
                <Border Background="#1e1e32" CornerRadius="8" Padding="10" Margin="0,0,0,5">
                  <StackPanel Spacing="5">
                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#e8e8ff"/>
                    <TextBlock FontSize="10" Foreground="#8888aa" FontFamily="Consolas,monospace">
                      <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} · {1:dd MMM HH:mm}">
                          <Binding Path="Entries.Count"/>
                          <Binding Path="LastModified"/>
                        </MultiBinding>
                      </TextBlock.Text>
                    </TextBlock>
                    <Grid ColumnDefinitions="*,Auto">
                      <Button Grid.Column="0"
                              Content="{Binding $parent[UserControl].DataContext.L.LoadButton}"
                              Background="#3b82f6" Foreground="White" FontSize="12" FontWeight="Bold"
                              Padding="0,7" CornerRadius="5" HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Center" Margin="0,0,4,0"
                              Command="{Binding $parent[UserControl].DataContext.LoadConsistCommand}"
                              CommandParameter="{Binding}" Cursor="Hand"/>
                      <Button Grid.Column="1" Content="✕" Background="Transparent" Foreground="#ef4444"
                              BorderBrush="#2e2e50" BorderThickness="1" Width="30" Height="30"
                              Padding="0" FontSize="13" CornerRadius="5"
                              HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                              Command="{Binding $parent[UserControl].DataContext.DeleteConsistCommand}"
                              CommandParameter="{Binding}" Cursor="Hand"/>
                    </Grid>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <Border Background="#2e2e50" Height="1"/>

          <!-- UIC History -->
          <Button Content="{Binding L.HistoryButton}"
                  Background="#252540" Foreground="#a0a0c0"
                  BorderBrush="#3a3a55" BorderThickness="1"
                  FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center" Padding="0,12" CornerRadius="8" Cursor="Hand"
                  Command="{Binding OpenHistoryDialogCommand}"/>

          <!-- Traction weight ratio -->
          <Button Background="#1e3a2e" Foreground="#22c55e"
                  BorderBrush="#22c55e" BorderThickness="1"
                  FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center" Padding="0,12" CornerRadius="8" Cursor="Hand"
                  IsEnabled="{Binding CanOpenTraction}"
                  Command="{Binding OpenTractionDialogCommand}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="&#xF0D1;" FontFamily="{StaticResource FaFont}" FontSize="14" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding L.TwrButton}" FontSize="14" FontWeight="SemiBold"/>
            </StackPanel>
          </Button>

          <Border Background="#2e2e50" Height="1"/>

          <!-- Language -->
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="🇨🇿" Padding="14,10" BorderThickness="0" CornerRadius="8"
                    FontSize="16" Cursor="Hand" Command="{Binding SetCzechCommand}">
              <Button.Background>
                <Binding Path="IsCzech">
                  <Binding.Converter><conv:BoolToColorConverter TrueColor="#f97316" FalseColor="#252540"/></Binding.Converter>
                </Binding>
              </Button.Background>
            </Button>
            <Button Content="🇬🇧" Padding="14,10" BorderThickness="0" CornerRadius="8"
                    FontSize="16" Cursor="Hand" Command="{Binding SetEnglishCommand}">
              <Button.Background>
                <Binding Path="IsEnglish">
                  <Binding.Converter><conv:BoolToColorConverter TrueColor="#f97316" FalseColor="#252540"/></Binding.Converter>
                </Binding>
              </Button.Background>
            </Button>
          </StackPanel>

        </StackPanel>
      </ScrollViewer>

    </Grid><!-- /mobile content -->

    <!-- ── BOTTOM NAV BAR ─────────────────────────────────────────────── -->
    <Border Grid.Row="3" Background="#161626" BorderBrush="#2e2e50" BorderThickness="0,1,0,0" Padding="0,0" MinHeight="72">
      <Grid ColumnDefinitions="*,*,*,*">

        <!-- Consist -->
        <Button Grid.Column="0" BorderThickness="0" Padding="0,10" HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center" Cursor="Hand"
                Command="{Binding SetMobileTabConsistCommand}" MinHeight="72">
          <Button.Background>
            <Binding Path="MobileTabConsist">
              <Binding.Converter><conv:BoolToColorConverter TrueColor="#1a1a2e" FalseColor="#161626"/></Binding.Converter>
            </Binding>
          </Button.Background>
          <StackPanel HorizontalAlignment="Center" Spacing="2" ClipToBounds="False">
            <TextBlock Text="{Binding L.NavConsistEmoji}" FontSize="18" TextAlignment="Center" FontFamily="{StaticResource FaFont}" Margin="2,0" Padding="0"/>
            <TextBlock Text="{Binding L.NavConsist}" FontSize="10" FontWeight="Bold" TextAlignment="Center">
              <TextBlock.Foreground>
                <Binding Path="MobileTabConsist">
                  <Binding.Converter><conv:BoolToColorConverter TrueColor="#f97316" FalseColor="#555577"/></Binding.Converter>
                </Binding>
              </TextBlock.Foreground>
            </TextBlock>
          </StackPanel>
        </Button>

        <!-- AddLoco -->
        <Button Grid.Column="1" BorderThickness="0" Padding="0,10" HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center" Cursor="Hand"
                Command="{Binding SetMobileTabAddLocoCommand}" MinHeight="72">
          <Button.Background>
            <Binding Path="MobileTabAddLoco">
              <Binding.Converter><conv:BoolToColorConverter TrueColor="#1a1a2e" FalseColor="#161626"/></Binding.Converter>
            </Binding>
          </Button.Background>
          <StackPanel HorizontalAlignment="Center" Spacing="2" ClipToBounds="False">
            <TextBlock Text="{Binding L.NavAddLocoEmoji}" FontSize="18" TextAlignment="Center" FontFamily="{StaticResource FaFont}" Margin="2,0" Padding="0"/>
            <TextBlock Text="{Binding L.NavAddLoco}" FontSize="10" FontWeight="Bold" TextAlignment="Center">
              <TextBlock.Foreground>
                <Binding Path="MobileTabAddLoco">
                  <Binding.Converter><conv:BoolToColorConverter TrueColor="#f97316" FalseColor="#555577"/></Binding.Converter>
                </Binding>
              </TextBlock.Foreground>
            </TextBlock>
          </StackPanel>
        </Button>

        <!-- Etcs -->
        <Button Grid.Column="2" BorderThickness="0" Padding="0,10" HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center" Cursor="Hand"
                Command="{Binding SetMobileTabEtcsCommand}" MinHeight="72">
          <Button.Background>
            <Binding Path="MobileTabEtcs">
              <Binding.Converter><conv:BoolToColorConverter TrueColor="#1a1a2e" FalseColor="#161626"/></Binding.Converter>
            </Binding>
          </Button.Background>
          <StackPanel HorizontalAlignment="Center" Spacing="2" ClipToBounds="False">
            <TextBlock Text="{Binding L.NavEtcsEmoji}" FontSize="18" TextAlignment="Center" FontFamily="{StaticResource FaFont}" Margin="2,0" Padding="0"/>
            <TextBlock Text="{Binding L.NavEtcs}" FontSize="10" FontWeight="Bold" TextAlignment="Center">
              <TextBlock.Foreground>
                <Binding Path="MobileTabEtcs">
                  <Binding.Converter><conv:BoolToColorConverter TrueColor="#f97316" FalseColor="#555577"/></Binding.Converter>
                </Binding>
              </TextBlock.Foreground>
            </TextBlock>
          </StackPanel>
        </Button>

        <!-- Menu -->
        <Button Grid.Column="3" BorderThickness="0" Padding="0,10" HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center" Cursor="Hand"
                Command="{Binding SetMobileTabMenuCommand}" MinHeight="72">
          <Button.Background>
            <Binding Path="MobileTabMenu">
              <Binding.Converter><conv:BoolToColorConverter TrueColor="#1a1a2e" FalseColor="#161626"/></Binding.Converter>
            </Binding>
          </Button.Background>
          <StackPanel HorizontalAlignment="Center" Spacing="2" ClipToBounds="False">
            <TextBlock Text="{Binding L.NavMenuEmoji}" FontSize="18" TextAlignment="Center" FontFamily="{StaticResource FaFont}" Margin="2,0" Padding="0"/>
            <TextBlock Text="{Binding L.NavMenu}" FontSize="10" FontWeight="Bold" TextAlignment="Center">
              <TextBlock.Foreground>
                <Binding Path="MobileTabMenu">
                  <Binding.Converter><conv:BoolToColorConverter TrueColor="#f97316" FalseColor="#555577"/></Binding.Converter>
                </Binding>
              </TextBlock.Foreground>
            </TextBlock>
          </StackPanel>
        </Button>



      </Grid>
    </Border>

  </Grid><!-- /mobile root grid -->

  <!-- ═══ TRACTION DIALOG OVERLAY ════════════════════════════════════════ -->
  <Border Background="#cc000010"
          IsVisible="{Binding TractionDialogVisible}" ZIndex="310">
    <Border Background="#2a2a3e" CornerRadius="12" Padding="26,22"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            MinWidth="340" MaxWidth="480"
            BorderBrush="#22c55e" BorderThickness="2">
      <StackPanel Spacing="14">

        <!-- Title -->
        <TextBlock Text="{Binding L.TwrButton}" FontSize="17" FontWeight="Bold" Foreground="#22c55e"/>

        <!-- Weight input -->
        <StackPanel Spacing="6">
          <TextBlock Text="{Binding L.TwrWeightLabel}" FontSize="12" Foreground="#a0a0c0"/>
          <TextBox Background="#1a1a2e" Foreground="#e8e8ff"
                   BorderBrush="#22c55e" BorderThickness="1"
                   CaretBrush="#e8e8ff" FontSize="15" Padding="10,8" CornerRadius="6"
                   Text="{Binding TractionWeightInput, Mode=TwoWay}"
                   Watermark="{Binding L.TwrWeightPh}"/>
        </StackPanel>

        <!-- No locos warning -->
        <Border IsVisible="{Binding TractionNoLocos}"
                Background="#1a2a1a" CornerRadius="5" Padding="10,7"
                BorderBrush="#22c55e" BorderThickness="1">
          <TextBlock Text="{Binding L.TwrNoLocos}"
                     FontSize="12" Foreground="#22c55e" TextWrapping="Wrap"/>
        </Border>

        <!-- Calculate button -->
        <Button Background="#22c55e" Foreground="#0f1a0f"
                FontSize="13" FontWeight="Bold" Padding="0,11"
                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                CornerRadius="7" BorderThickness="0"
                IsEnabled="{Binding TractionInputValid}"
                Command="{Binding CalculateTractionCommand}" Cursor="Hand"
                Content="{Binding L.TwrCalculate}"/>

        <!-- Result -->
        <StackPanel Spacing="8" IsVisible="{Binding TractionHasResult}">

          <!-- Table used + ΣTWR -->
          <Grid ColumnDefinitions="*">
            <Border Grid.Column="1" Background="#1a2a1a" CornerRadius="5" Padding="12,6"
                    BorderBrush="#3a3a55" BorderThickness="1" Margin="0">
              <StackPanel Spacing="2">
                <TextBlock Text="{Binding L.TwrSumTitle}" FontSize="10" Foreground="#a0a0c0"/>
                <TextBlock Text="{Binding TractionSumLabel}" FontSize="15" FontWeight="Bold" Foreground="#e8e8ff"/>
              </StackPanel>
            </Border>
          </Grid>

          <!-- Per-loco shares -->
          <Border Background="#1e1e32" CornerRadius="6"
                  BorderBrush="#3a3a55" BorderThickness="1" Padding="0">
            <ItemsControl ItemsSource="{Binding TractionShares}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:TractionShareViewModel">
                  <Grid ColumnDefinitions="*,Auto,Auto" Margin="10,7,10,7">
                    <TextBlock Grid.Column="0" Text="{Binding Designation}"
                               FontSize="13" Foreground="#e8e8ff" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding TwrLabel}"
                               FontSize="11" Foreground="#8888aa"
                               VerticalAlignment="Center" Margin="8,0"/>
                    <TextBlock Grid.Column="2" Text="{Binding AssignedWeightTx}"
                               FontSize="13" FontWeight="Bold" Foreground="#22c55e"
                               VerticalAlignment="Center" FontFamily="Consolas,monospace"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>

        </StackPanel>

        <!-- Close button -->
        <Button Content="{Binding L.CloseButton}"
                Background="#2a2a3e" Foreground="#a0a0c0"
                FontSize="13" Padding="0,11" HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center" BorderBrush="#3a3a55" BorderThickness="1"
                CornerRadius="7" Command="{Binding CloseTractionDialogCommand}" Cursor="Hand"/>

      </StackPanel>
    </Border>
  </Border>

    <!-- ═══ EDB DIALOG OVERLAY — Panel level: works on desktop and mobile ═══ -->
  <Border Background="#cc000010"
          IsVisible="{Binding EdbDialogVisible}" ZIndex="300">
    <Border Background="#2a2a3e" CornerRadius="12" Padding="28,22"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            MaxWidth="420" BorderBrush="#f97316" BorderThickness="2">
      <StackPanel Spacing="14">
        <TextBlock Text="{Binding L.EdbDialogTitle}" FontSize="17" FontWeight="Bold" Foreground="#f97316"/>
        <TextBlock Text="{Binding EdbDialogBody}" FontSize="13" Foreground="#e2e2f0"
                   TextWrapping="Wrap" LineHeight="22"/>
        <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
          <Button Grid.Column="0" Content="{Binding L.EdbYes}" Background="#f97316" Foreground="White"
                  FontSize="13" FontWeight="Bold" Padding="0,11" HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center" CornerRadius="7" Margin="0,0,6,0"
                  BorderThickness="0" Command="{Binding EdbYesCommand}" Cursor="Hand"/>
          <Button Grid.Column="1" Content="{Binding L.EdbNo}" Background="#2a2a3e" Foreground="#a0a0c0"
                  FontSize="13" Padding="0,11" HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center" BorderBrush="#3a3a55" BorderThickness="1"
                  CornerRadius="7" Command="{Binding EdbNoCommand}" Cursor="Hand"/>
        </Grid>
      </StackPanel>
    </Border>
  </Border>

  <!-- ═══ HISTORY DIALOG OVERLAY ══════════════════════════════════════ -->
  <Border Background="#cc000010"
          IsVisible="{Binding HistoryDialogVisible}" ZIndex="290">
    <Border Background="#2a2a3e" CornerRadius="12" Padding="24,20"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            MinWidth="320" MaxWidth="460" MaxHeight="560"
            BorderBrush="#3a3a55" BorderThickness="1">
      <Grid RowDefinitions="Auto,*,Auto">

        <TextBlock Grid.Row="0" Text="{Binding L.HistoryDialogTitle}"
                   FontSize="17" FontWeight="Bold" Foreground="#e8e8ff" Margin="0,0,0,14"/>

        <!-- Empty state -->
        <TextBlock Grid.Row="1" Text="{Binding L.HistoryEmpty}"
                   IsVisible="{Binding HistoryIsEmpty}"
                   Foreground="#8888aa" FontSize="13"
                   VerticalAlignment="Center" HorizontalAlignment="Center"/>

        <!-- History list -->
        <ScrollViewer Grid.Row="1" IsVisible="{Binding !HistoryIsEmpty}"
                      VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding UicHistoryItems}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:UicHistoryItemViewModel">
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,6">
                  <TextBlock Grid.Column="0" Text="{Binding Designation}"
                             FontSize="11" Foreground="#8888aa"
                             VerticalAlignment="Center" Margin="0,0,10,0" MinWidth="60"/>
                  <TextBlock Grid.Column="1" Text="{Binding FormattedUic}"
                             FontSize="13" FontFamily="Consolas,monospace"
                             Foreground="#e8e8ff" VerticalAlignment="Center"/>
                  <Button Grid.Column="2" Content="✕"
                          Background="Transparent" Foreground="#ef4444"
                          BorderBrush="#2e2e50" BorderThickness="1"
                          Width="28" Height="28" Padding="0" FontSize="12" CornerRadius="5"
                          HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                          Command="{Binding $parent[UserControl].DataContext.DeleteHistoryItemCommand}"
                          CommandParameter="{Binding}" Cursor="Hand"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <!-- Close button -->
        <Button Grid.Row="2" Content="{Binding L.CloseButton}"
                Background="#2a2a3e" Foreground="#a0a0c0"
                FontSize="13" Padding="0,11" HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center" BorderBrush="#3a3a55" BorderThickness="1"
                CornerRadius="7" Margin="0,16,0,0"
                Command="{Binding CloseHistoryDialogCommand}" Cursor="Hand"/>
      </Grid>
    </Border>
  </Border>

  <!-- ═══ RENAME DIALOG OVERLAY ═══════════════════════════════════════ -->
  <Border Background="#cc000010"
          IsVisible="{Binding RenameDialogVisible}" ZIndex="300">
    <Border Background="#2a2a3e" CornerRadius="12" Padding="28,22"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            MaxWidth="440" BorderBrush="#3b82f6" BorderThickness="2">
      <StackPanel Spacing="14">
        <TextBlock Text="{Binding L.RenameDialogTitle}" FontSize="17" FontWeight="Bold" Foreground="#3b82f6"/>
        <TextBlock Text="{Binding L.RenameDialogBody}" FontSize="13" Foreground="#e2e2f0"
                   TextWrapping="Wrap" LineHeight="22"/>
        <TextBox x:Name="RenameTextBox"
                 Background="#1a1a2e" Foreground="#e8e8ff"
                 BorderBrush="#3b82f6" BorderThickness="1"
                 CaretBrush="#e8e8ff"
                 FontFamily="Consolas,monospace" FontSize="15" Padding="10,8" CornerRadius="6"
                 TextChanged="OnRenameTextChanged"
                 MaxLength="17"/>
        <!-- UIC prefix mismatch warning -->
        <Border IsVisible="{Binding RenameUicMismatchVisible}"
                Background="#2d1a00" CornerRadius="5" Padding="10,7"
                BorderBrush="#f97316" BorderThickness="1">
          <TextBlock Text="{Binding L.RenameUicMismatch}"
                     FontSize="12" Foreground="#f97316" TextWrapping="Wrap"/>
        </Border>
        <!-- Check digit warning -->
        <Border IsVisible="{Binding RenameCheckDigitInvalid}"
                Background="#2d0a0a" CornerRadius="5" Padding="10,7"
                BorderBrush="#ef4444" BorderThickness="1">
          <TextBlock Text="{Binding RenameCheckDigitWarning}"
                     FontSize="12" Foreground="#ef4444" TextWrapping="Wrap"/>
        </Border>
        <!-- History suggestions -->
        <Border IsVisible="{Binding RenameHistoryVisible}"
                Background="#1e1e32" CornerRadius="6"
                BorderBrush="#3a3a55" BorderThickness="1" MaxHeight="130">
          <ListBox x:Name="RenameHistoryList"
                   Background="Transparent"
                   ItemsSource="{Binding RenameHistorySuggestions}"
                   SelectionChanged="OnRenameHistorySelectionChanged">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:RenameHistorySuggestion">
                <TextBlock Text="{Binding Formatted}" FontFamily="Consolas,monospace"
                           FontSize="13" Foreground="#a0c4ff" Padding="6,8"/>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>
        <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
          <Button Grid.Column="0" Content="{Binding L.RenameConfirm}" Background="#3b82f6" Foreground="White"
                  FontSize="13" FontWeight="Bold" Padding="0,11" HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center" CornerRadius="7" Margin="0,0,6,0"
                  BorderThickness="0" Command="{Binding ConfirmRenameCommand}" Cursor="Hand"/>
          <Button Grid.Column="1" Content="{Binding L.RenameCancel}" Background="#2a2a3e" Foreground="#a0a0c0"
                  FontSize="13" Padding="0,11" HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center" BorderBrush="#3a3a55" BorderThickness="1"
                  CornerRadius="7" Command="{Binding CancelRenameCommand}" Cursor="Hand"/>
        </Grid>
      </StackPanel>
    </Border>
  </Border>

  <!-- ═══ TOAST NOTIFICATION ══════════════════════════════════════════ -->
  <!-- Second child of Panel — floats above everything via ZIndex        -->
  <Border x:Name="ToastBorder"
          CornerRadius="8" Padding="14,10"
          HorizontalAlignment="Center" VerticalAlignment="Bottom"
          Margin="0,0,0,32"
          Opacity="0" IsHitTestVisible="False"
          ZIndex="500">
    <Border.Background>
      <Binding Path="IsErrorToast">
        <Binding.Converter><conv:BoolToColorConverter TrueColor="#2a1010" FalseColor="#1e2a1e"/></Binding.Converter>
      </Binding>
    </Border.Background>
    <Border.BorderBrush>
      <Binding Path="IsErrorToast">
        <Binding.Converter><conv:BoolToColorConverter TrueColor="#ef4444" FalseColor="#22c55e"/></Binding.Converter>
      </Binding>
    </Border.BorderBrush>
    <Border.BorderThickness><Thickness>1</Thickness></Border.BorderThickness>
    <TextBlock x:Name="ToastText"
               FontSize="13" FontWeight="SemiBold"
               Text="{Binding StatusMessage}">
      <TextBlock.Foreground>
        <Binding Path="IsErrorToast">
          <Binding.Converter><conv:BoolToColorConverter TrueColor="#fca5a5" FalseColor="#22c55e"/></Binding.Converter>
        </Binding>
      </TextBlock.Foreground>
    </TextBlock>
  </Border>

  </Panel>
</UserControl>
