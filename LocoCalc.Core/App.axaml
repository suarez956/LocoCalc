<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LocoCalc.App"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <FluentTheme/>
    <Style Selector="AutoCompleteBox /template/ ListBox ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="#33558bcc"/>
    </Style>
    <Style Selector="AutoCompleteBox /template/ ListBox ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1a558bcc"/>
    </Style>
  </Application.Styles>
  <Application.Resources>
    <!-- Embedded NotoColorEmoji guarantees emoji rendering on all Android versions -->
    <FontFamily x:Key="EmojiFont">avares://LocoCalc.Core/Assets#Noto Color Emoji</FontFamily>
    <!-- Font Awesome 6 Free Solid for UI icons -->
    <FontFamily x:Key="FaFont">avares://LocoCalc.Core/Assets#Font Awesome 6 Free Solid</FontFamily>
  </Application.Resources>
</Application>
